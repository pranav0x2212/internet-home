{
  "outputDirectory": "site/rendered",
  "routes": [
    {
      "src": "/blogs/?",
      "dest": "/blogs/index.html"
    },
    {
      "src": "/blogs/(.*)",
      "dest": "/blogs/$1.html"
    },
    {
      "src": "/til/?",
      "dest": "/til/index.html"
    },
    {
      "src": "/til/(.*)",
      "dest": "/til/$1.html"
    }
  ]
}